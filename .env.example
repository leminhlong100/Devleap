# Sao chép file này thành .env.local rồi điền giá trị từ Supabase Dashboard
# (Project Settings → API). File .env.local đã được .gitignore (qua *.local).
#
# Nếu để trống, app vẫn chạy bình thường ở chế độ khách (chỉ lưu localStorage,
# không đồng bộ đa thiết bị).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
